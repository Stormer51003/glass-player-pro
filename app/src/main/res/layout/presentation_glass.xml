<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.media3.ui.PlayerView
        android:id="@+id/glassPlayerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"/>

    <TextureView
        android:id="@+id/hiddenTexture"
        android:layout_width="1px"
        android:layout_height="1px"
        android:layout_gravity="bottom|end"
        android:alpha="0"/>

    <com.stormer.glassplayer.SwapSurfaceView
        android:id="@+id/swapOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- Dim overlay for glasses brightness control (alpha = 1 - brightness) -->
    <View
        android:id="@+id/dimOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:alpha="0"/>

</FrameLayout>
